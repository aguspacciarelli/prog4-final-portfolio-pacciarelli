---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactForm from "@/components/ContactForm.tsx";
---

<BaseLayout title="Charlemos">
  <section class="flex flex-col gap-10">
    <h1 class="text-4xl font-medium lg:text-5xl">&gt; Charlemos</h1>

    <div class="flex flex-col gap-10 lg:flex-row lg:gap-40">
      <p class="text-gris-oscuro text-[1.125rem]">
        ¿Tenés un proyecto en mente o una consulta? Escribime y lo pensamos
        juntos.
      </p>
      <ContactForm client:load />
    </div>
  </section>
</BaseLayout>
