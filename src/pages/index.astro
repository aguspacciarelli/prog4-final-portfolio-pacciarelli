---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Button from "@/components/Button.astro";
import CardCarousel from "@/components/CardCarousel.astro";
import data from "@/data/data.json";
---

<BaseLayout title="Inicio">
  <div class="flex flex-col gap-6">

<div class="px-30 flex flex-col gap-8">

<div class="flex flex-col gap-5">

      <div class="grid grid-cols-[auto_1fr] items-baseline-last gap-x-16 w-full">

        <h1 class="text-8xl tracking-[-0.4rem] font-medium">Diseñadora</h1>
        <p class="justify-self-end text-[18px] text-right leading-5.5 text-gris-oscuro">
          Creo marcas y productos con una <br> narrativa sólida y experiencias
          estéticas <br> que los usuarios disfrutan usar
        </p>
        <h2 class="text-8xl tracking-[-0.4rem] font-medium">Digital</h2>

      </div>

      <div class="grid grid-cols-[1fr_auto] items-baseline-last gap-x-8 w-full leading-5.5">

        <p class="text-[18px] w-1/3 text-gris-oscuro">
          Diseño UX/UI, Branding, Dirección Creativa, Experiencias Digitales <br> y
          mucho más :)
        </p>
        <h2 class="text-8xl text-right tracking-[-0.4rem] font-medium">Agustina</h2>

        <p class="w-1/3 text-[18px] leading-5.5 text-gris-oscuro">
          Buenos Aires, <br> Argentina
        </p>
        <h2 class="text-8xl text-right tracking-[-0.4rem] font-medium">Pacciarelli</h2>

      </div>

    </div>

    <div class="flex flex-col gap-1.5">

      <a href="/charlemos" class="boton-principal text-[20px] self-start px-6 py-1.5">Hablemos!</a>
      <p class="text-gris-medio">Disponible para trabajo freelance y part/full time</p>
      
    </div>

</div>

    <div class="mt-35 flex flex-col gap-8">
      <div class="mx-30 relative flex items-center justify-center">
        <h3 class="titulos-secciones">/Mis proyectos favoritos</h3>
        <a
          href="/proyectos"
          class="boton-principal absolute top-1/2 right-0 -translate-y-1/2 text-[20px] px-6 py-1.5"
        >
          Ver todos →
        </a>
      </div>
      <CardCarousel />
    </div>

  </div>
</BaseLayout>
