---
import CvAccordion from "@/components/CvAccordion.jsx";
import cv from "@/data/cv.json";

const secciones = cv.secciones;
---

<div class="flex flex-col gap-12">
  {
    secciones.map((sec) => (
      <div class="flex flex-col gap-4 lg:flex-row lg:gap-16">
        <h3 class="text-[1.25rem] font-medium lg:w-1/4 lg:shrink-0">
          {sec.titulo}
        </h3>

        <div class="lg:flex-1">
          {sec.layout === "acordeon" ? (
            <CvAccordion client:load items={sec.items} />
          ) : (
            <div class="flex flex-col">
              {sec.items.map((item) => {

                /* Bloque de texto siempre visible */
                if (item.tipo === "texto")
                  return (
                    <div class="border-b border-gris-claro/60 py-4">
                      <p class="font-medium lg:text-[1.125rem]">{item.titulo}</p>
                      <p class="mt-1 leading-6 text-gris-oscuro">
                        {item.detalle}
                      </p>
                    </div>
                  );

                /* Bloque de toolbox */
                if (item.tipo === "iconos")
                  return (
                    <div class="border-b border-gris-claro/60 py-4">
                      <p class="lg:text-[1.125rem] font-medium">{item.titulo}</p>
                      <div class="mt-3 flex flex-wrap gap-3">
                        {item.iconos.map((icon) => (
                          <img
                            src={icon.src}
                            alt={icon.nombre}
                            title={icon.nombre}
                            class="h-10 w-10 object-contain"
                          />
                        ))}
                      </div>
                    </div>
                  );

                /* Bloque de certificados */
                if (item.tipo === "link")
                  return (
                    <a
                      href={item.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="group flex items-start justify-between gap-4 border-b border-gris-claro/60 py-4"
                    >
                      <span class="flex flex-col">
                        <span class="flex flex-row items-center lg:items-baseline gap-x-2">
                          <span class="lg:text-[1.125rem] leading-5">{item.titulo}</span>
                          <span class="text-gris-medio">|</span>
                          <span class="font-medium leading-5">{item.empresa}</span>
                        </span>
                        <span class="mt-0.5 text-gris-medio">
                          {item.fecha}
                        </span>
                      </span>
                      <svg
                        class="mt-1 h-5 w-5 shrink-0 text-gris-medio transition-transform duration-200 group-hover:-translate-y-0.5 group-hover:translate-x-0.5 group-hover:text-negro"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <line x1="7" y1="17" x2="17" y2="7" />
                        <polyline points="7 7 17 7 17 17" />
                      </svg>
                    </a>
                  );

                return null;
              })}
            </div>
          )}
        </div>
      </div>
    ))
  }
</div>
