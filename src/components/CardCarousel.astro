---
import { proyectos } from "@/data/proyectos.json";

const { cards = proyectos } = Astro.props;
---

<!-- Div contenedor de las cards de los proyectos -->
<div
  data-card-carousel
  tabindex="0"
  class="relative -mx-6 h-125 lg:h-155 cursor-grab touch-pan-y overflow-hidden select-none md:-mx-12 lg:-mx-30 [&.dragging]:cursor-grabbing"
>

<!-- Cards de proyectos individuales -->
  {
    cards.map((card) => (
      <article class="card group absolute top-8 left-1/2 w-70 will-change-transform [&.is-active]:z-10">
        <img
          src={card.image}
          alt={card.titulo}
          draggable="false"
          class="aspect-4/5 w-full rounded-2xl object-cover grayscale transition-[filter] duration-700 ease-out select-none group-[.is-active]:grayscale-0"
        />

        <div class="pointer-events-none mt-5 flex w-full flex-col gap-2 opacity-0 transition-opacity duration-700 ease-out group-[.is-active]:pointer-events-auto group-[.is-active]:opacity-100">
          <h3 class="text-2xl font-medium">{card.titulo}</h3>
          <p class="text-[15px] text-gris-medio font-medium">{card.fecha}</p>
          <p class="text-[15px] text-gris-medio">{card.subtitulo}</p>
          <p class="text-[15px] leading-5.5 text-gris-oscuro">{card.cuerpo}</p>
          <a
            href={card?.link}
            class="boton-principal mt-1 self-start px-5 py-1.5 text-[16px]"
          >
            {card.boton}
          </a>
        </div>
      </article>
    ))
  }
</div>

<script>
  // @ts-nocheck
  const CARD_W = 280;
  const GAP = 45;
  const W = CARD_W + GAP;
  const BEND = 70;

  function lerp(a, b, t) {
    return a + (b - a) * t;
  }

  function debounce(fn, wait) {
    let t;
    return () => {
      clearTimeout(t);
      t = window.setTimeout(fn, wait);
    };
  }

  document
    .querySelectorAll("[data-card-carousel]")
    .forEach((root) => {
      const baseCards = Array.from(root.querySelectorAll(".card"));
      if (!baseCards.length) return;

      // Clonar cards hasta cubrir de sobra el ancho de pantalla
      const coverage = Math.max(window.innerWidth, 2560) * 2;
      while (root.querySelectorAll(".card").length * W < coverage) {
        baseCards.forEach((c) => root.appendChild(c.cloneNode(true)));
      }

      const cards = Array.from(root.querySelectorAll(".card"));
      const N = cards.length;
      const total = N * W;

      const TOP_OFFSET = 32;
      const ajustarAltura = () => {
        const tallest = Math.max(...cards.map((c) => c.offsetHeight));
        root.style.height = `${TOP_OFFSET + tallest + BEND}px`;
      };
      ajustarAltura();
      document.fonts?.ready.then(ajustarAltura);

      const scroll = { current: 0, target: 0, ease: 0.07 };
      
      
      const startIndex = Math.floor(baseCards.length / 2);
      scroll.current = scroll.target = startIndex * W;

      let activeEl = null;

      function render() {
        scroll.current = lerp(scroll.current, scroll.target, scroll.ease);


        const H = window.innerWidth / 2;
        const R = (H * H + BEND * BEND) / (2 * BEND);

        let best = null;
        let bestDist = Infinity;

        for (let i = 0; i < N; i++) {
          const card = cards[i];
          let x = i * W - scroll.current;
        
          x = x - total * Math.round(x / total);
          const dist = Math.abs(x);
    
          const ex = Math.min(dist, H);
          const y = R - Math.sqrt(R * R - ex * ex);
          const angle = Math.sign(x) * Math.asin(ex / R) * (180 / Math.PI);

          const s = 0.85 + (1 - Math.min(dist / W, 1)) * 0.15;
          card.style.transform = `translate(calc(-50% + ${x}px), ${y}px) rotate(${angle}deg) scale(${s})`;

          if (dist < bestDist) {
            bestDist = dist;
            best = card;
          }
        }

        if (best && best !== activeEl) {
          activeEl?.classList.remove("is-active");
          best.classList.add("is-active");
          activeEl = best;
        }

        requestAnimationFrame(render);
      }
      requestAnimationFrame(render);

      const snap = () => {
        scroll.target = Math.round(scroll.target / W) * W;
      };
      const snapDebounced = debounce(snap, 120);

      root.addEventListener(
        "wheel",
        (e) => {
          if (Math.abs(e.deltaX) <= Math.abs(e.deltaY)) return;
          e.preventDefault();
          scroll.target += e.deltaX;
          snapDebounced();
        },
        { passive: false },
      );

      let down = false;
      let startX = 0;
      let startTarget = 0;
      let moved = false;
      let captured = false;
      let pointerId = -1;
      root.addEventListener("pointerdown", (e) => {
        down = true;
        moved = false;
        captured = false;
        startX = e.clientX;
        startTarget = scroll.target;
        pointerId = e.pointerId;
      });
      root.addEventListener("pointermove", (e) => {
        if (!down) return;
        const dx = e.clientX - startX;
        if (Math.abs(dx) > 4 && !captured) {
          moved = true;
          captured = true;
          root.classList.add("dragging");
          root.setPointerCapture(pointerId);
        }
        if (captured) scroll.target = startTarget - dx;
      });
      const up = () => {
        if (!down) return;
        down = false;
        if (captured) {
          root.classList.remove("dragging");
          if (root.hasPointerCapture(pointerId)) root.releasePointerCapture(pointerId);
          captured = false;
          snap();
        }
      };
      root.addEventListener("pointerup", up);
      root.addEventListener("pointercancel", up);

      root.addEventListener("keydown", (e) => {
        if (e.key === "ArrowRight") {
          e.preventDefault();
          scroll.target += W;
          snap();
        } else if (e.key === "ArrowLeft") {
          e.preventDefault();
          scroll.target -= W;
          snap();
        }
      });

      root.addEventListener(
        "click",
        (e) => {
          if (moved) {
            e.preventDefault();
            e.stopPropagation();
            moved = false;
          }
        },
        true,
      );
    });
</script>
