---

---

{/* Desktop */}
<section class="hidden lg:flex lg:flex-col lg:gap-15">
  <div class="flex flex-col gap-5">
    <div class="grid w-full grid-cols-[auto_1fr] items-baseline-last gap-x-16">
      <h1 class="text-8xl font-medium tracking-[-0.4rem]">Diseñadora</h1>
      <p
        class="justify-self-end text-right text-[18px] leading-5.5 text-gris-oscuro"
      >
        Creo marcas y productos con una <br /> narrativa sólida y experiencias estéticas
        <br /> que los usuarios disfrutan usar
      </p>
      <h2 class="text-8xl font-medium tracking-[-0.4rem]">Digital</h2>
    </div>

    <div
      class="grid w-full grid-cols-[1fr_auto] items-baseline-last gap-x-8 leading-5.5"
    >
      <p class="w-1/3 text-[18px] text-gris-oscuro">
        Diseño UX/UI, Branding, Dirección Creativa, Experiencias Digitales <br
        /> y mucho más :)
      </p>
      <h2 class="text-right text-8xl font-medium tracking-[-0.4rem]">
        Agustina
      </h2>

      <p class="w-1/3 text-[18px] leading-5.5 text-gris-oscuro">
        Buenos Aires, <br /> Argentina
      </p>
      <h2 class="text-right text-8xl font-medium tracking-[-0.4rem]">
        Pacciarelli
      </h2>
    </div>
  </div>

  <div class="flex flex-col gap-3">
    <a
      href="/charlemos"
      class="boton-principal self-start px-6 py-1.5 text-[20px]"
    >
      Hablemos!
    </a>
    <div class="flex flex-row items-center gap-2">
      <img src="/disponible.svg" alt="Disponibilidad" class="lg:h-4 lg:" />
      <p class="text-gris-medio">
        Disponible para trabajo freelance y part/full time
      </p>
    </div>
  </div>
</section>

{/* Tablet y Mobile */}
<section class="flex flex-col gap-12 lg:hidden">
  <div class="text-left">
    <h2 class="text-5xl font-medium tracking-[-0.3rem] sm:text-7xl">
      Diseñadora <br /> Digital
    </h2>
    <p class="w-3/4 mt-4 text-[18px] leading-5.5 text-gris-oscuro">
      Creo marcas y productos con una narrativa sólida y experiencias estéticas
      que los usuarios disfrutan usar
    </p>
  </div>

  {/* Agustina Pacciarelli + servicios, a la derecha */}
  <div class="text-right">
    <h2 class="text-5xl font-medium tracking-[-0.3rem] sm:text-7xl">
      Agustina <br /> Pacciarelli
    </h2>
    <p
      class="w-3/4 mt-4 ml-auto max-w-md text-[18px] leading-5.5 text-gris-oscuro"
    >
      Diseño UX/UI, Branding, Dirección Creativa, Experiencias Digitales y mucho
      más :)
    </p>
  </div>

  {/* Botón + ubicación + disponibilidad, centrado */}
  <div class="flex flex-col items-center gap-3 text-center">
    <a href="/charlemos" class="boton-principal px-6 py-1.5 text-[18px]">
      Hablemos!
    </a>
    <div class="flex flex-col gap-0.5">
      <p class="text-gris-medio">Buenos Aires, Argentina</p>
      <div class="flex flex-row items-center gap-1">
        <img src="/disponible.svg" alt="Disponibilidad" class="h-2" />
        <p class="text-gris-medio">
          Disponible para trabajo freelance y part/full time
        </p>
      </div>
    </div>
  </div>
</section>
